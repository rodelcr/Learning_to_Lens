(* Content-type: application/vnd.wolfram.mathematica *)

(*** Wolfram Notebook File ***)
(* Created by Module 7: Axisymmetric Lens Models *)

Notebook[{

(* --- Title --- *)
Cell["Module 7: Axisymmetric Lens Models \[Dash] Interactive Explorations", "Title"],

Cell["This notebook provides interactive Manipulate widgets for exploring the SIS, NIS, and NFW lens models. Use the sliders to vary model parameters and observe how image positions, magnifications, convergence, and shear profiles change.", "Text"],

Cell["Sources: Narayan & Bartelmann Sec. 3.1 & 3.4, Congdon & Keeton Ch. 2.3 & 6.1\[Dash]6.2", "Text"],


(* ===================================================================== *)
Cell["Section 1: Singular Isothermal Sphere (SIS)", "Section"],

Cell["The SIS has a constant physical deflection angle: \[Alpha]hat = 4\[Pi]\[Sigma]_v^2/c^2. The Einstein radius depends on the velocity dispersion and the distance ratio Dds/Ds.", "Text"],

Cell["SIS: Vary \[Sigma]_v and Source Position", "Subsection"],

Cell[BoxData[
 RowBox[{"Manipulate", "[",
  RowBox[{
   RowBox[{"Module", "[",
    RowBox[{
     RowBox[{"{", "thetaE, thetaP, thetaM, muP, muM, DdsOverDs", "}"}],
     ",",
     RowBox[{
      RowBox[{"DdsOverDs", "=", "0.706"}], ";",
      RowBox[{"thetaE", "=",
       RowBox[{"4", " ", "Pi", " ",
        SuperscriptBox[
         RowBox[{"(", RowBox[{"sigmaV", "/", "3*^5"}], ")"}], "2"],
        " ", "DdsOverDs", " ", "206265"}]}], ";",
      RowBox[{"thetaP", "=",
       RowBox[{"beta", "+", "thetaE"}]}], ";",
      RowBox[{"thetaM", "=",
       RowBox[{"beta", "-", "thetaE"}]}], ";",
      RowBox[{"muP", "=",
       RowBox[{"If", "[",
        RowBox[{
         RowBox[{"beta", ">", "0.01"}], ",",
         RowBox[{"1", "+", RowBox[{"thetaE", "/", "beta"}]}], ",",
         "Infinity"}], "]"}]}], ";",
      RowBox[{"muM", "=",
       RowBox[{"If", "[",
        RowBox[{
         RowBox[{"beta", ">", "0.01"}], ",",
         RowBox[{"Abs", "[",
          RowBox[{"1", "-", RowBox[{"thetaE", "/", "beta"}]}], "]"}], ",",
         "Infinity"}], "]"}]}], ";",
      RowBox[{"Column", "[", RowBox[{"{",
       RowBox[{
        RowBox[{"Row", "[", RowBox[{"{",
         RowBox[{
          RowBox[{"Style", "[",
           RowBox[{
            RowBox[{"StringForm", "[",
             RowBox[{"\"\\!\\(\\*SubscriptBox[\\(\\[Theta]\\), \\(E\\)]\\) = `` arcsec\"",
              ",",
              RowBox[{"NumberForm", "[", RowBox[{"thetaE", ",", RowBox[{"{", RowBox[{"4", ",", "2"}], "}"}]}], "]"}]}],
             "]"}], ",", "14"}], "]"}]}
        , "}"}], "]"}], ",",
        RowBox[{"Graphics", "[", RowBox[{
         RowBox[{"{",
          RowBox[{
           RowBox[{"{", RowBox[{"Blue", ",", "Dashed", ",",
            RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",",
            RowBox[{"Circle", "[",
             RowBox[{
              RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}], ",",
              "thetaE"}], "]"}]}], "}"}], ",",
           RowBox[{"{", RowBox[{"Black", ",",
            RowBox[{"Disk", "[",
             RowBox[{
              RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}], ",",
              "0.05"}], "]"}]}], "}"}], ",",
           RowBox[{"{",
            RowBox[{"Darker", "[", "Green", "]"}], ",",
            RowBox[{"PointSize", "[", "0.02", "]"}], ",",
            RowBox[{"Point", "[",
             RowBox[{"{", RowBox[{"0", ",", "beta"}], "}"}], "]"}], "}"}], ",",
           RowBox[{"If", "[",
            RowBox[{
             RowBox[{"beta", "<", "thetaE"}], ",",
             RowBox[{"{",
              RowBox[{
               RowBox[{"{", RowBox[{"Red", ",",
                RowBox[{"PointSize", "[", "0.015", "]"}], ",",
                RowBox[{"Point", "[",
                 RowBox[{"{", RowBox[{"0", ",", "thetaP"}], "}"}], "]"}]}], "}"}], ",",
               RowBox[{"{", RowBox[{"Red", ",",
                RowBox[{"PointSize", "[", "0.015", "]"}], ",",
                RowBox[{"Point", "[",
                 RowBox[{"{", RowBox[{"0", ",", "thetaM"}], "}"}], "]"}]}], "}"}]}],
             "}"}], ",",
             RowBox[{"{", RowBox[{"Red", ",",
              RowBox[{"PointSize", "[", "0.015", "]"}], ",",
              RowBox[{"Point", "[",
               RowBox[{"{", RowBox[{"0", ",", "thetaP"}], "}"}], "]"}]}], "}"}]}],
           "]"}]}],
         "}"}], ",",
         RowBox[{"PlotRange", "->",
          RowBox[{"{",
           RowBox[{
            RowBox[{"{", RowBox[{"-3", ",", "3"}], "}"}], ",",
            RowBox[{"{", RowBox[{"-3", ",", "3"}], "}"}]}], "}"}]}], ",",
         RowBox[{"ImageSize", "->", "350"}], ",",
         RowBox[{"Frame", "->", "True"}], ",",
         RowBox[{"AspectRatio", "->", "1"}]}],
        "]"}], ",",
        RowBox[{"If", "[",
         RowBox[{
          RowBox[{"beta", ">", "0.01"}], ",",
          RowBox[{"Column", "[", RowBox[{"{",
           RowBox[{
            RowBox[{"StringForm", "[",
             RowBox[{"\"\\!\\(\\*SubscriptBox[\\(\\[Theta]\\), \\(+\\)]\\) = `` arcsec, |\\!\\(\\*SubscriptBox[\\(\\[Mu]\\), \\(+\\)]\\)| = ``\"",
              ",",
              RowBox[{"NumberForm", "[", RowBox[{"thetaP", ",", RowBox[{"{", RowBox[{"4", ",", "2"}], "}"}]}], "]"}], ",",
              RowBox[{"NumberForm", "[", RowBox[{"muP", ",", RowBox[{"{", RowBox[{"4", ",", "2"}], "}"}]}], "]"}]}],
             "]"}], ",",
            RowBox[{"If", "[",
             RowBox[{
              RowBox[{"beta", "<", "thetaE"}], ",",
              RowBox[{"StringForm", "[",
               RowBox[{"\"\\!\\(\\*SubscriptBox[\\(\\[Theta]\\), \\(-\\)]\\) = `` arcsec, |\\!\\(\\*SubscriptBox[\\(\\[Mu]\\), \\(-\\)]\\)| = ``\"",
                ",",
                RowBox[{"NumberForm", "[", RowBox[{"thetaM", ",", RowBox[{"{", RowBox[{"4", ",", "2"}], "}"}]}], "]"}], ",",
                RowBox[{"NumberForm", "[", RowBox[{"muM", ",", RowBox[{"{", RowBox[{"4", ",", "2"}], "}"}]}], "]"}]}],
               "]"}], ",",
              "\"Single image\""}],
            "]"}]}],
          "}"}], "]"}], ",",
          "\"Source at center (Einstein ring)\""}],
        "]"}]}],
      "}"}], "]"}]}]}],
   "]"}], ",",
   RowBox[{"{",
    RowBox[{
     RowBox[{"{", RowBox[{"sigmaV", ",", "250", ",",
      RowBox[{"\"\\!\\(\\*SubscriptBox[\\(\\[Sigma]\\), \\(v\\)]\\) (km/s)\""}]}], "}"}], ",",
     "100", ",", "400"}], "}"}], ",",
   RowBox[{"{",
    RowBox[{
     RowBox[{"{", RowBox[{"beta", ",", "0.5", ",",
      "\"\[Beta] (arcsec)\""}], "}"}], ",",
     "0", ",", "3", ",", "0.01"}], "}"}]}],
  "]"}]
], "Input"],


(* ===================================================================== *)
Cell["Section 2: Nonsingular Isothermal Sphere (NIS)", "Section"],

Cell["The NIS adds a core radius \[Theta]_c that removes the central singularity. As \[Theta]_c increases, the central convergence decreases, and eventually the lens can no longer produce multiple images.", "Text"],

Cell["NIS: Slider for Core Radius", "Subsection"],

Cell[BoxData[
 RowBox[{"Manipulate", "[",
  RowBox[{
   RowBox[{"Module", "[",
    RowBox[{
     RowBox[{"{", "kappa0", "}"}],
     ",",
     RowBox[{
      RowBox[{"kappa0", "=",
       RowBox[{"1", "/",
        RowBox[{"(", RowBox[{"2", " ", "thetac"}], ")"}]}]}], ";",
      RowBox[{"GraphicsRow", "[", RowBox[{"{",
       RowBox[{
        RowBox[{"Plot", "[",
         RowBox[{
          RowBox[{"{",
           RowBox[{
            RowBox[{"1", "/",
             RowBox[{"(", RowBox[{"2",
              RowBox[{"Sqrt", "[",
               RowBox[{
                SuperscriptBox["theta", "2"], "+",
                SuperscriptBox["thetac", "2"]}], "]"}]}], ")"}]}], ",",
            RowBox[{"1", "/",
             RowBox[{"(", RowBox[{"2", " ", "theta"}], ")"}]}], ",",
            "1"}],
          "}"}], ",",
          RowBox[{"{", RowBox[{"theta", ",", "0.01", ",", "4"}], "}"}], ",",
          RowBox[{"PlotStyle", "->",
           RowBox[{"{",
            RowBox[{
             RowBox[{"{", RowBox[{"Blue", ",",
              RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "}"}], ",",
             RowBox[{"{", RowBox[{"Gray", ",", "Dashed", ",",
              RowBox[{"AbsoluteThickness", "[", "1", "]"}]}], "}"}], ",",
             RowBox[{"{", RowBox[{"Gray", ",", "Dotted", ",",
              RowBox[{"AbsoluteThickness", "[", "1", "]"}]}], "}"}]}],
           "}"}]}], ",",
          RowBox[{"PlotRange", "->",
           RowBox[{"{",
            RowBox[{
             RowBox[{"{", RowBox[{"0", ",", "4"}], "}"}], ",",
             RowBox[{"{", RowBox[{"0", ",", "5"}], "}"}]}], "}"}]}], ",",
          RowBox[{"PlotLabel", "->",
           RowBox[{"Style", "[",
            RowBox[{
             RowBox[{"StringForm", "[",
              RowBox[{"\"\\[Kappa](0) = ``\"",
               ",",
               RowBox[{"NumberForm", "[", RowBox[{"kappa0", ",",
                RowBox[{"{", RowBox[{"4", ",", "2"}], "}"}]}], "]"}]}],
             "]"}], ",", "13"}], "]"}]}], ",",
          RowBox[{"ImageSize", "->", "350"}]}],
        "]"}], ",",
        RowBox[{"Plot", "[",
         RowBox[{
          RowBox[{"theta", "-",
           RowBox[{
            RowBox[{"(",
             RowBox[{
              RowBox[{"Sqrt", "[",
               RowBox[{
                SuperscriptBox["theta", "2"], "+",
                SuperscriptBox["thetac", "2"]}], "]"}], "-",
              "thetac"}], ")"}], "/", "theta"}]}], ",",
          RowBox[{"{", RowBox[{"theta", ",", "0.01", ",", "4"}], "}"}], ",",
          RowBox[{"PlotStyle", "->",
           RowBox[{"{", RowBox[{"Red", ",",
            RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "}"}]}], ",",
          RowBox[{"PlotRange", "->",
           RowBox[{"{",
            RowBox[{
             RowBox[{"{", RowBox[{"0", ",", "4"}], "}"}], ",",
             RowBox[{"{", RowBox[{"-1", ",", "3"}], "}"}]}], "}"}]}], ",",
          RowBox[{"PlotLabel", "->",
           RowBox[{"Style", "[",
            RowBox[{"\"NIS Lens Equation: \\[Beta](\\[Theta])\"", ",", "13"}], "]"}]}], ",",
          RowBox[{"AxesLabel", "->",
           RowBox[{"{",
            RowBox[{"\"\\[Theta]\"", ",", "\"\\[Beta]\""}], "}"}]}], ",",
          RowBox[{"Epilog", "->",
           RowBox[{"{", RowBox[{"Gray", ",", "Dashed", ",",
            RowBox[{"InfiniteLine", "[",
             RowBox[{
              RowBox[{"{",
               RowBox[{
                RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}], ",",
                RowBox[{"{", RowBox[{"1", ",", "1"}], "}"}]}], "}"}]}],
            "]"}]}], "}"}]}], ",",
          RowBox[{"ImageSize", "->", "350"}]}],
        "]"}]}],
      "}"}], "]"}]}]}],
   "]"}], ",",
   RowBox[{"{",
    RowBox[{
     RowBox[{"{", RowBox[{"thetac", ",", "0.2", ",",
      RowBox[{"\"\\!\\(\\*SubscriptBox[\\(\\[Theta]\\), \\(c\\)]\\) / \\!\\(\\*SubscriptBox[\\(\\[Theta]\\), \\(E\\)]\\)\""}]}], "}"}], ",",
     "0.01", ",", "1.0"}], "}"}]}],
  "]"}]
], "Input"],


(* ===================================================================== *)
Cell["Section 3: NFW Profile", "Section"],

Cell["The NFW profile is the universal dark matter halo profile from N-body simulations. The concentration parameter c controls how centrally concentrated the mass is.", "Text"],

Cell["NFW: Concentration Slider", "Subsection"],

Cell[BoxData[
 RowBox[{"Manipulate", "[",
  RowBox[{
   RowBox[{"Module", "[",
    RowBox[{
     RowBox[{"{", "fFunc, gFunc, kbarFunc, gammaFunc", "}"}],
     ",",
     RowBox[{
      RowBox[{"fFunc", "[", "x_", "]"}], ":=",
       RowBox[{"Piecewise", "[",
        RowBox[{"{",
         RowBox[{
          RowBox[{"{",
           RowBox[{
            RowBox[{
             RowBox[{"(", RowBox[{"1", "/",
              RowBox[{"(",
               RowBox[{
                SuperscriptBox["x", "2"], "-", "1"}], ")"}]}], ")"}],
             RowBox[{"(",
              RowBox[{"1", "-",
               RowBox[{
                RowBox[{"ArcCosh", "[",
                 RowBox[{"1", "/", "x"}], "]"}], "/",
                RowBox[{"Sqrt", "[",
                 RowBox[{"1", "-",
                  SuperscriptBox["x", "2"]}], "]"}]}]}], ")"}]}], ",",
            RowBox[{"x", "<", "1"}]}], "}"}], ",",
          RowBox[{"{",
           RowBox[{
            RowBox[{"1", "/", "3"}], ",",
            RowBox[{"x", "==", "1"}]}], "}"}], ",",
          RowBox[{"{",
           RowBox[{
            RowBox[{
             RowBox[{"(", RowBox[{"1", "/",
              RowBox[{"(",
               RowBox[{
                SuperscriptBox["x", "2"], "-", "1"}], ")"}]}], ")"}],
             RowBox[{"(",
              RowBox[{"1", "-",
               RowBox[{
                RowBox[{"ArcTan", "[",
                 RowBox[{"Sqrt", "[",
                  RowBox[{
                   SuperscriptBox["x", "2"], "-", "1"}], "]"}], "]"}], "/",
                RowBox[{"Sqrt", "[",
                 RowBox[{
                  SuperscriptBox["x", "2"], "-", "1"}], "]"}]}]}], ")"}]}], ",",
            RowBox[{"x", ">", "1"}]}], "}"}]}],
        "}"}], "]"}]}], ";",
     RowBox[{
      RowBox[{"gFunc", "[", "x_", "]"}], ":=",
       RowBox[{"Piecewise", "[",
        RowBox[{"{",
         RowBox[{
          RowBox[{"{",
           RowBox[{
            RowBox[{
             RowBox[{"ArcCosh", "[",
              RowBox[{"1", "/", "x"}], "]"}], "/",
             RowBox[{"Sqrt", "[",
              RowBox[{"1", "-",
               SuperscriptBox["x", "2"]}], "]"}]}], ",",
            RowBox[{"x", "<", "1"}]}], "}"}], ",",
          RowBox[{"{",
           RowBox[{"1", ",",
            RowBox[{"x", "==", "1"}]}], "}"}], ",",
          RowBox[{"{",
           RowBox[{
            RowBox[{
             RowBox[{"ArcTan", "[",
              RowBox[{"Sqrt", "[",
               RowBox[{
                SuperscriptBox["x", "2"], "-", "1"}], "]"}], "]"}], "/",
             RowBox[{"Sqrt", "[",
              RowBox[{
               SuperscriptBox["x", "2"], "-", "1"}], "]"}]}], ",",
            RowBox[{"x", ">", "1"}]}], "}"}]}],
        "}"}], "]"}]}], ";",
     RowBox[{
      RowBox[{"kbarFunc", "[", "x_", "]"}], ":=",
       RowBox[{
        RowBox[{"(", RowBox[{"4", "/",
         SuperscriptBox["x", "2"]}], ")"}],
        RowBox[{"(",
         RowBox[{
          RowBox[{"Log", "[",
           RowBox[{"x", "/", "2"}], "]"}], "+",
          RowBox[{"gFunc", "[", "x", "]"}]}], ")"}]}]}], ";",
     RowBox[{
      RowBox[{"gammaFunc", "[", "x_", "]"}], ":=",
       RowBox[{
        RowBox[{"kbarFunc", "[", "x", "]"}], "-",
        RowBox[{"fFunc", "[", "x", "]"}]}]}], ";",
     RowBox[{"Plot", "[",
      RowBox[{
       RowBox[{"{",
        RowBox[{
         RowBox[{"fFunc", "[", "x", "]"}], ",",
         RowBox[{"Abs", "[",
          RowBox[{"gammaFunc", "[", "x", "]"}], "]"}]}],
       "}"}], ",",
       RowBox[{"{", RowBox[{"x", ",", "0.05", ",",
        RowBox[{"conc", " ", "1.5"}]}], "}"}], ",",
       RowBox[{"PlotStyle", "->",
        RowBox[{"{",
         RowBox[{
          RowBox[{"{", RowBox[{"Blue", ",",
           RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "}"}], ",",
          RowBox[{"{", RowBox[{"Red", ",",
           RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Dashed"}], "}"}]}],
        "}"}]}], ",",
       RowBox[{"PlotRange", "->",
        RowBox[{"{",
         RowBox[{
          RowBox[{"{", RowBox[{"0", ",",
           RowBox[{"conc", " ", "1.5"}]}], "}"}], ",",
          RowBox[{"{", RowBox[{"0", ",", "3"}], "}"}]}], "}"}]}], ",",
       RowBox[{"AxesLabel", "->",
        RowBox[{"{",
         RowBox[{
          RowBox[{"Style", "[",
           RowBox[{"\"x = \\[Theta]/\\!\\(\\*SubscriptBox[\\(\\[Theta]\\), \\(s\\)]\\)\"", ",", "13"}], "]"}], ",",
          RowBox[{"Style", "[",
           RowBox[{"\"Amplitude / \\!\\(\\*SubscriptBox[\\(\\[Kappa]\\), \\(s\\)]\\)\"", ",", "13"}], "]"}]}], "}"}]}], ",",
       RowBox[{"PlotLabel", "->",
        RowBox[{"Style", "[",
         RowBox[{
          RowBox[{"StringForm", "[", RowBox[{"\"NFW Profile (c = ``)\"", ",", "conc"}], "]"}], ",",
          "14"}], "]"}]}], ",",
       RowBox[{"PlotLegends", "->",
        RowBox[{"Placed", "[",
         RowBox[{
          RowBox[{"LineLegend", "[",
           RowBox[{
            RowBox[{"{",
             RowBox[{
              RowBox[{"Style", "[", RowBox[{"\"\\[Kappa]/\\!\\(\\*SubscriptBox[\\(\\[Kappa]\\), \\(s\\)]\\)\"", ",", "11"}], "]"}], ",",
              RowBox[{"Style", "[", RowBox[{"\"|\\[Gamma]|/\\!\\(\\*SubscriptBox[\\(\\[Kappa]\\), \\(s\\)]\\)\"", ",", "11"}], "]"}]}],
            "}"}]}], "]"}], ",",
          RowBox[{"{", RowBox[{"0.7", ",", "0.7"}], "}"}]}],
        "]"}]}], ",",
       RowBox[{"Epilog", "->",
        RowBox[{"{", RowBox[{"Gray", ",", "Dashed", ",",
         RowBox[{"AbsoluteThickness", "[", "1", "]"}], ",",
         RowBox[{"InfiniteLine", "[",
          RowBox[{"{",
           RowBox[{
            RowBox[{"{", RowBox[{"conc", ",", "0"}], "}"}], ",",
            RowBox[{"{", RowBox[{"conc", ",", "10"}], "}"}]}], "}"}],
         "]"}], ",",
         RowBox[{"Text", "[",
          RowBox[{
           RowBox[{"Style", "[",
            RowBox[{"\"x = c (virial)\"", ",", "9", ",", "Gray"}], "]"}], ",",
           RowBox[{"{",
            RowBox[{
             RowBox[{"conc", " ", "1.1"}], ",", "2.5"}], "}"}]}],
         "]"}]}], "}"}]}], ",",
       RowBox[{"ImageSize", "->", "550"}]}],
     "]"}]}]}],
   "]"}], ",",
   RowBox[{"{",
    RowBox[{
     RowBox[{"{", RowBox[{"conc", ",", "10", ",", "\"Concentration c\""}], "}"}], ",",
     "2", ",", "30", ",", "1"}], "}"}]}],
  "]"}]
], "Input"],


(* ===================================================================== *)
Cell["Section 4: Model Comparison Panel", "Section"],

Cell["Compare all four axisymmetric models side by side.", "Text"],

Cell[BoxData[
 RowBox[{"Module", "[",
  RowBox[{
   RowBox[{"{", "}"}], ",",
   RowBox[{"GraphicsRow", "[",
    RowBox[{
     RowBox[{"{",
      RowBox[{
       RowBox[{"Plot", "[",
        RowBox[{
         RowBox[{"{",
          RowBox[{
           RowBox[{"1", "/",
            RowBox[{"(", RowBox[{"2", " ", "theta"}], ")"}]}], ",",
           RowBox[{"1", "/",
            RowBox[{"(", RowBox[{"2",
             RowBox[{"Sqrt", "[",
              RowBox[{
               SuperscriptBox["theta", "2"], "+",
               "0.04"}], "]"}]}], ")"}]}], ",",
           RowBox[{
            SuperscriptBox["theta", "2"], "/",
            SuperscriptBox["theta", "2"]}]}],
         "}"}], ",",
         RowBox[{"{", RowBox[{"theta", ",", "0.1", ",", "4"}], "}"}], ",",
         RowBox[{"PlotStyle", "->",
          RowBox[{"{",
           RowBox[{
            RowBox[{"{", RowBox[{"Blue", ",",
             RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "}"}], ",",
            RowBox[{"{", RowBox[{"Red", ",",
             RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Dashed"}], "}"}], ",",
            RowBox[{"{", RowBox[{"Gray", ",",
             RowBox[{"AbsoluteThickness", "[", "1", "]"}], ",", "Dotted"}], "}"}]}],
          "}"}]}], ",",
         RowBox[{"PlotRange", "->",
          RowBox[{"{",
           RowBox[{
            RowBox[{"{", RowBox[{"0", ",", "4"}], "}"}], ",",
            RowBox[{"{", RowBox[{"0", ",", "3"}], "}"}]}], "}"}]}], ",",
         RowBox[{"PlotLabel", "->",
          RowBox[{"Style", "[", RowBox[{"\"Convergence Profiles\"", ",", "13"}], "]"}]}], ",",
         RowBox[{"PlotLegends", "->",
          RowBox[{"{", RowBox[{"\"SIS\"", ",", "\"NIS\"", ",", "\"\\[Kappa] = 1\""}], "}"}]}], ",",
         RowBox[{"ImageSize", "->", "350"}]}],
       "]"}], ",",
       RowBox[{"Plot", "[",
        RowBox[{
         RowBox[{"{",
          RowBox[{
           RowBox[{"1", "/", "theta"}], ",",
           "1", ",",
           RowBox[{
            RowBox[{"(",
             RowBox[{
              RowBox[{"Sqrt", "[",
               RowBox[{
                SuperscriptBox["theta", "2"], "+", "0.04"}], "]"}], "-",
              "0.2"}], ")"}], "/", "theta"}]}],
         "}"}], ",",
         RowBox[{"{", RowBox[{"theta", ",", "0.1", ",", "4"}], "}"}], ",",
         RowBox[{"PlotStyle", "->",
          RowBox[{"{",
           RowBox[{
            RowBox[{"{", RowBox[{"Black", ",",
             RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Dotted"}], "}"}], ",",
            RowBox[{"{", RowBox[{"Blue", ",",
             RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "}"}], ",",
            RowBox[{"{", RowBox[{"Red", ",",
             RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Dashed"}], "}"}]}],
          "}"}]}], ",",
         RowBox[{"PlotRange", "->",
          RowBox[{"{",
           RowBox[{
            RowBox[{"{", RowBox[{"0", ",", "4"}], "}"}], ",",
            RowBox[{"{", RowBox[{"0", ",", "4"}], "}"}]}], "}"}]}], ",",
         RowBox[{"PlotLabel", "->",
          RowBox[{"Style", "[", RowBox[{"\"Deflection Angles\"", ",", "13"}], "]"}]}], ",",
         RowBox[{"PlotLegends", "->",
          RowBox[{"{", RowBox[{"\"Point mass\"", ",", "\"SIS\"", ",", "\"NIS\""}], "}"}]}], ",",
         RowBox[{"ImageSize", "->", "350"}]}],
       "]"}]}],
     "}"}], ",",
     RowBox[{"Spacings", "->", "10"}]}],
   "]"}]}],
  "]"}]
], "Input"]

},
WindowSize->{1024, 768},
WindowTitle->"Module 7: Axisymmetric Lens Models"
]

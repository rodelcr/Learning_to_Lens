Cell[CellGroupData[{
Cell["Module 1a: Four-Vectors and Spacetime Diagrams", "Title",ExpressionUUID->"a9f40c5d-80ac-4b08-a9ee-f77259f5a84b"],

Cell["\<\
This notebook provides interactive visualizations of special relativity \
concepts. Each section builds on the Lorentz transformation formalism \
developed in lorentz_transforms.wl and the LaTeX notes.\
\>", "Text",ExpressionUUID->"304a5874-8c72-4470-84ce-cb3fdefc1306"],

Cell[CellGroupData[{

Cell["1. The Minkowski Metric and Interval Classification", "Section",ExpressionUUID->"0d7d66c1-62c6-48e2-8722-616cc69d634f"],

Cell["\<\
The spacetime interval ds^2 = -dt^2 + dx^2 + dy^2 + dz^2 classifies event \
separations as timelike (ds^2 < 0), null (ds^2 = 0), or spacelike (ds^2 > 0). \
We work in natural units c = 1.\
\>", "Text",ExpressionUUID->"95c2c44e-a0a1-46b7-96a2-94292931b7b5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "the", " ", "Minkowski", " ", "metric"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{"\[Eta]", " ", "=", " ", 
    RowBox[{"DiagonalMatrix", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", " ", "1", ",", " ", "1", ",", " ", "1"}], 
      "}"}], "]"}]}], "\n", 
   RowBox[{"MatrixForm", "[", "\[Eta]", "]"}]}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"ff0ccf49-0d3e-4020-bde3-95892bd63c42"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.983003350606965*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"2cd2fbf6-8e50-4477-af22-d46c1b43d9a0"],


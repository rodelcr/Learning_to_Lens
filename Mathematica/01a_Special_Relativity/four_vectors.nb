Cell[CellGroupData[{

Cell["2. Spacetime Diagram with Light Cones", "Section",ExpressionUUID->"ff7c5a29-1425-48c2-970f-6001acbf9da0"],

Cell["\<\
Interactive spacetime diagram showing the light cone structure. The light \
cone divides spacetime into timelike (inside), null (on the cone), and \
spacelike (outside) regions. Cf. Carroll Figures 1.2 and 1.5.\
\>", "Text",ExpressionUUID->"defd5495-836c-453a-853a-b27c74864db5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Spacetime", " ", 
    RowBox[{"diagram", ":", " ", 
     RowBox[{"1", "+", 
      RowBox[{"1", " ", "dimensions", " ", "for", " ", "clarity"}]}]}]}], " ",
    "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Light", " ", "cones", " ", "are", " ", "the", " ", "lines", " ", "x"}], 
    " ", "=", " ", 
    RowBox[{"+", 
     RowBox[{"/", 
      RowBox[{"-", " ", "t"}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"lightConePlot", " ", "=", " ", 
     RowBox[{"Show", "[", "\n", 
      RowBox[{"(*", " ", 
       RowBox[{"Shade", " ", "the", " ", "timelike", " ", "region"}], " ", 
       "*)"}], "\n", 
      RowBox[{
       RowBox[{"RegionPlot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], " ", "<", " ", 
          RowBox[{"t", "^", "2"}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", 
           RowBox[{"-", "3"}], ",", " ", "3"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"t", ",", " ", 
           RowBox[{"-", "3"}], ",", " ", "3"}], "}"}], ",", "\n", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"Directive", "[", 
           RowBox[{"LightBlue", ",", " ", 
            RowBox[{"Opacity", "[", "0.3", "]"}]}], "]"}]}], ",", "\n", 
         RowBox[{"BoundaryStyle", " ", "->", " ", "None"}]}], "]"}], ",", 
       "\n", 
       RowBox[{"(*", " ", 
        RowBox[{"Light", " ", "cone", " ", "lines"}], " ", "*)"}], "\n", 
       RowBox[{"Plot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", " ", 
           RowBox[{"-", "x"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", 
           RowBox[{"-", "3"}], ",", " ", "3"}], "}"}], ",", "\n", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Orange", ",", " ", "Dashed", ",", " ", "Thick"}], "}"}],
             ",", " ", 
            RowBox[{"{", 
             RowBox[{"Orange", ",", " ", "Dashed", ",", " ", "Thick"}], 
             "}"}]}], "}"}]}]}], "]"}], ",", "\n", 
       RowBox[{"(*", " ", 
        RowBox[{"Example", " ", "worldlines"}], " ", "*)"}], "\n", 
       RowBox[{"Graphics", "[", 
        RowBox[{"{", "\n", 
         RowBox[{"(*", " ", 
          RowBox[{"Stationary", " ", 
           RowBox[{"particle", ":", " ", 
            RowBox[{"vertical", " ", "worldline"}]}]}], " ", "*)"}], "\n", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Blue", ",", " ", "Thick", ",", " ", 
            RowBox[{"Arrow", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", " ", 
                 RowBox[{"-", "2.5"}]}], "}"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"0", ",", " ", "2.5"}], "}"}]}], "}"}], "]"}]}], 
           "}"}], ",", "\n", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Moving", " ", 
             RowBox[{"particle", ":", " ", "v"}]}], " ", "=", " ", "0.5"}], 
           " ", "*)"}], "\n", 
          RowBox[{"{", 
           RowBox[{"Red", ",", " ", "Thick", ",", " ", 
            RowBox[{"Arrow", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "0.5"}], " ", "*", " ", "2.5", ",", " ", 
                 RowBox[{"-", "2.5"}]}], "}"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"0.5", " ", "*", " ", "2.5", ",", " ", "2.5"}], 
                "}"}]}], "}"}], "]"}]}], "}"}], ",", "\n", 
          RowBox[{"(*", " ", "Labels", " ", "*)"}], "\n", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Text", "[", 
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<Timelike\\n(inside cone)\>\"", ",", " ", "12", ",",
                " ", "Blue"}], "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"0", ",", " ", "1.5"}], "}"}], "]"}], ",", "\n", 
            RowBox[{"Text", "[", 
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<Spacelike\\n(outside)\>\"", ",", " ", "12", ",", 
               " ", 
               RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"2.2", ",", " ", "0.5"}], "}"}], "]"}], ",", "\n", 
            RowBox[{"Text", "[", 
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<Light cone\\n(null)\>\"", ",", " ", "12", ",", " ",
                "Orange"}], "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"2", ",", " ", "2.5"}], "}"}], "]"}]}], "}"}]}], "}"}], 
        "]"}], ",", "\n", 
       RowBox[{"AxesLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", " ", "\"\<t\>\""}], "}"}]}], ",", "\n", 
       RowBox[{
       "PlotLabel", " ", "->", " ", "\"\<Spacetime Diagram (1+1D)\>\""}], ",",
        "\n", 
       RowBox[{"AspectRatio", " ", "->", " ", "1"}], ",", "\n", 
       RowBox[{"ImageSize", " ", "->", " ", "500"}]}], "]"}]}], ";"}], "\n", 
   "lightConePlot"}]}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"4bd2d129-935d-4777-a0ca-7c026b72206b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Interactive Lorentz Boost", "Section",ExpressionUUID->"24e0ea00-22f6-468f-82de-c820d2dad042"],

Cell["\<\
Use the slider to vary the boost velocity v and see how the (t', x') axes \
tilt. Light cones (x = +/- t) are invariant under boosts. Cf. Carroll Figure \
1.7.\
\>", "Text",ExpressionUUID->"aa04480b-dcb1-471d-a2cd-939bb2276849"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Interactive", " ", "Lorentz", " ", 
    RowBox[{"boost", ":", " ", 
     RowBox[{
     "see", " ", "how", " ", "the", " ", "primed", " ", "axes", " ", 
      "tilt"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"The", " ", 
      RowBox[{"t", "'"}], " ", "axis", " ", "is", " ", "the", " ", "line", " ",
       "x"}], " ", "=", " ", 
     RowBox[{"v", "*", "t"}]}], ";", " ", 
    RowBox[{
     RowBox[{"the", " ", 
      RowBox[{"x", "'"}], " ", "axis", " ", "is", " ", "t"}], " ", "=", " ", 
     RowBox[{"v", "*", "x"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"Manipulate", "[", "\n", 
   RowBox[{
    RowBox[{"Show", "[", "\n", 
     RowBox[{"(*", " ", 
      RowBox[{"Light", " ", "cone"}], " ", "*)"}], "\n", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", " ", 
          RowBox[{"-", "x"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", 
          RowBox[{"-", "3"}], ",", " ", "3"}], "}"}], ",", "\n", 
        RowBox[{"PlotStyle", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Orange", ",", " ", "Dashed"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"Orange", ",", " ", "Dashed"}], "}"}]}], "}"}]}]}], "]"}],
       ",", "\n", 
      RowBox[{"(*", " ", 
       RowBox[{"Primed", " ", "axes"}], " ", "*)"}], "\n", 
      RowBox[{"Graphics", "[", 
       RowBox[{"{", "\n", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"t", "'"}], " ", 
            RowBox[{"axis", ":", " ", "x"}]}], " ", "=", " ", 
           RowBox[{"v", "*", "t"}]}], ",", " ", 
          RowBox[{
           RowBox[{"so", " ", "t"}], " ", "=", " ", 
           RowBox[{
            RowBox[{"x", "/", "v"}], " ", "for", " ", "display", " ", "as", " ",
             "x", 
            RowBox[{"(", "t", ")"}]}]}]}], " ", "*)"}], "\n", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Red", ",", " ", "Thick", ",", " ", 
           RowBox[{"Arrow", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"vBoost", " ", "*", " ", "2.8"}], ",", " ", "2.8"}], 
               "}"}]}], "}"}], "]"}]}], "}"}], ",", "\n", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "'"}], " ", 
            RowBox[{"axis", ":", " ", "t"}]}], " ", "=", " ", 
           RowBox[{"v", "*", "x"}]}], " ", "*)"}], "\n", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Darker", "[", "Red", "]"}], ",", " ", "Thick", ",", " ", 
           RowBox[{"Arrow", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"2.8", ",", " ", 
                RowBox[{"vBoost", " ", "*", " ", "2.8"}]}], "}"}]}], "}"}], 
            "]"}]}], "}"}], ",", "\n", 
         RowBox[{"(*", " ", "Labels", " ", "*)"}], "\n", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<t'\>\"", ",", " ", "14", ",", " ", "Red", ",", " ",
                "Bold"}], "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"vBoost", "*", "2.8", " ", "+", " ", "0.2"}], ",", " ",
                "2.9"}], "}"}]}], "]"}], ",", "\n", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<x'\>\"", ",", " ", "14", ",", " ", 
               RowBox[{"Darker", "[", "Red", "]"}], ",", " ", "Bold"}], "]"}],
              ",", " ", 
             RowBox[{"{", 
              RowBox[{"2.9", ",", " ", 
               RowBox[{"vBoost", "*", "2.8", " ", "+", " ", "0.2"}]}], 
              "}"}]}], "]"}]}], "}"}]}], "}"}], "]"}], ",", "\n", 
      RowBox[{"AxesLabel", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<x\>\"", ",", " ", "\"\<t\>\""}], "}"}]}], ",", "\n", 
      RowBox[{"PlotRange", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "3"}], ",", " ", "3"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "3"}], ",", " ", "3"}], "}"}]}], "}"}]}], ",", "\n", 
      RowBox[{"AspectRatio", " ", "->", " ", "1"}], ",", "\n", 
      RowBox[{"PlotLabel", " ", "->", " ", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<Lorentz Boost: v = \>\"", ",", " ", 
          RowBox[{"NumberForm", "[", 
           RowBox[{"vBoost", ",", " ", "2"}], "]"}], ",", 
          " ", "\"\<, \[Gamma] = \>\"", ",", " ", 
          RowBox[{"NumberForm", "[", 
           RowBox[{
            RowBox[{"1", "/", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"1", " ", "-", " ", 
               RowBox[{"vBoost", "^", "2"}]}], "]"}]}], ",", " ", 

Cell[CellGroupData[{

Cell["5. Twin Paradox (Carroll Fig. 1.6)", "Section",ExpressionUUID->"21767be1-1447-4f52-9f39-5d2a2166c750"],

Cell["\<\
The traveling twin takes a longer path through space but a shorter path \
through spacetime (less proper time). This is the geometric origin of the \
twin paradox \[AHat]\.80\.94 in Minkowski space, the straight path has the \
LONGEST proper time, opposite to Euclidean intuition.\
\>", "Text",ExpressionUUID->"f1153267-3e15-4572-9bf2-678e3ccdc22d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Twin", " ", 
    RowBox[{"paradox", ":", " ", 
     RowBox[{
     "compare", " ", "proper", " ", "times", " ", "along", " ", "two", " ", 
      "paths"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"Manipulate", "[", "\n", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "totalT", ",", " ", "halfT", ",", " ", "xTurn", ",", " ", "tauStay", ",",
         " ", "tauTravel"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"totalT", " ", "=", " ", "4"}], ";", "\n", 
       RowBox[{"halfT", " ", "=", " ", 
        RowBox[{"totalT", "/", "2"}]}], ";", "\n", 
       RowBox[{"xTurn", " ", "=", " ", 
        RowBox[{"vTwin", " ", "*", " ", "halfT"}]}], ";", "\n", 
       RowBox[{"tauStay", " ", "=", " ", "totalT"}], ";", "\n", 
       RowBox[{"tauTravel", " ", "=", " ", 
        RowBox[{"totalT", " ", "*", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"vTwin", "^", "2"}]}], "]"}]}]}], ";", "\n", 
       RowBox[{"Show", "[", "\n", 
        RowBox[{
         RowBox[{"Graphics", "[", 
          RowBox[{"{", "\n", 
           RowBox[{"(*", " ", 
            RowBox[{"Stationary", " ", 
             RowBox[{"twin", ":", " ", 
              RowBox[{"straight", " ", "worldline"}]}]}], " ", "*)"}], "\n", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Blue", ",", " ", "Thick", ",", " ", 
              RowBox[{"Arrow", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
                 RowBox[{"{", 
                  RowBox[{"0", ",", " ", "totalT"}], "}"}]}], "}"}], "]"}]}], 
             "}"}], ",", "\n", 
            RowBox[{"(*", " ", 
             RowBox[{"Traveling", " ", 
              RowBox[{"twin", ":", " ", 
               RowBox[{"bent", " ", "worldline"}]}]}], " ", "*)"}], "\n", 
            RowBox[{"{", 
             RowBox[{"Red", ",", " ", "Thick", ",", " ", 
              RowBox[{"Arrow", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
                 RowBox[{"{", 
                  RowBox[{"xTurn", ",", " ", "halfT"}], "}"}]}], "}"}], "]"}],
               ",", "\n", 
              RowBox[{"Arrow", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"xTurn", ",", " ", "halfT"}], "}"}], ",", " ", 
                 RowBox[{"{", 
                  RowBox[{"0", ",", " ", "totalT"}], "}"}]}], "}"}], "]"}]}], 
             "}"}], ",", "\n", 
            RowBox[{"(*", " ", "Labels", " ", "*)"}], "\n", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Text", "[", 
               RowBox[{
                RowBox[{"Style", "[", 
                 RowBox[{
                  RowBox[{"Row", "[", 
                   RowBox[{"{", 
                    RowBox[{"\"\<Stay: \[Tau] = \>\"", ",", " ", 
                    RowBox[{"NumberForm", "[", 
                    RowBox[{"tauStay", ",", " ", "3"}], "]"}]}], "}"}], "]"}],
                   ",", " ", "12", ",", " ", "Blue"}], "]"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "1"}], ",", " ", "2"}], "}"}]}], "]"}], ",", 
              "\n", 
              RowBox[{"Text", "[", 
               RowBox[{
                RowBox[{"Style", "[", 
                 RowBox[{
                  RowBox[{"Row", "[", 
                   RowBox[{"{", 
                    RowBox[{"\"\<Travel: \[Tau] = \>\"", ",", " ", 
                    RowBox[{"NumberForm", "[", 
                    RowBox[{"tauTravel", ",", " ", 
                    RowBox[{"{", 
                    RowBox[{"4", ",", " ", "2"}], "}"}]}], "]"}]}], "}"}], 
                   "]"}], ",", " ", "12", ",", " ", "Red"}], "]"}], ",", " ", 
                
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"xTurn", " ", "+", " ", "0.5"}], ",", " ", "2"}], 
                 "}"}]}], "]"}]}], "}"}]}], "}"}], "]"}], ",", "\n", 
         RowBox[{"Axes", " ", "->", " ", "True"}], ",", "\n", 
         RowBox[{"AxesLabel", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"\"\<x\>\"", ",", " ", "\"\<t\>\""}], "}"}]}], ",", "\n", 
         RowBox[{"PlotRange", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "2"}], ",", " ", "3"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "0.5"}], ",", " ", "5"}], "}"}]}], "}"}]}], ",", 
         "\n", 
         RowBox[{"AspectRatio", " ", "->", " ", "1"}], ",", "\n", 
         RowBox[{"PlotLabel", " ", "->", " ", "\"\<Twin Paradox\>\""}], ",", 
         "\n", 
         RowBox[{"ImageSize", " ", "->", " ", "400"}]}], "]"}]}]}], "]"}], ",",
     "\n", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "vTwin", ",", " ", "0.6", ",", " ", "\"\<Travel velocity v/c\>\""}], 
       "}"}], ",", " ", "0.1", ",", " ", "0.95", ",", " ", "0.01"}], "}"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"9ee6204f-8b2a-4e7e-9d77-4a1cf2e2459f"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`vTwin$$ = 0.6, Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`vTwin$$], 0.6, "Travel velocity v/c"}, 0.1, 0.95, 
      0.01, ControlType -> Manipulator}}, Typeset`size$$ = {
    400., {203.20705837673611`, 208.93899197048611`}}, Typeset`update$$ = 0, 
    Typeset`initDone$$, Typeset`skipInitDone$$ = True, 
    Typeset`keyframeActionsQ$$ = False, Typeset`keyframeList$$ = {}}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, "Variables" :> {$CellContext`vTwin$$ = 0.6}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$, Typeset`keyframeActionsQ$$, 
        Typeset`keyframeList$$}, "Body" :> 
      Module[{$CellContext`totalT$, $CellContext`halfT$, $CellContext`xTurn$, \
$CellContext`tauStay$, $CellContext`tauTravel$}, $CellContext`totalT$ = 
         4; $CellContext`halfT$ = $CellContext`totalT$/
          2; $CellContext`xTurn$ = $CellContext`vTwin$$ $CellContext`halfT$; \
$CellContext`tauStay$ = $CellContext`totalT$; $CellContext`tauTravel$ = \
$CellContext`totalT$ Sqrt[1 - $CellContext`vTwin$$^2]; Show[
          Graphics[{{Blue, Thick, 
             Arrow[{{0, 0}, {0, $CellContext`totalT$}}]}, {Red, Thick, 
             Arrow[{{0, 0}, {$CellContext`xTurn$, $CellContext`halfT$}}], 
             
             Arrow[{{$CellContext`xTurn$, $CellContext`halfT$}, {
               0, $CellContext`totalT$}}]}, {
             Text[
              Style[
               Row[{"Stay: \[Tau] = ", 
                 NumberForm[$CellContext`tauStay$, 3]}], 12, Blue], {-1, 2}], 
             
             Text[
              Style[
               Row[{"Travel: \[Tau] = ", 
                 NumberForm[$CellContext`tauTravel$, {4, 2}]}], 12, 
               Red], {$CellContext`xTurn$ + 0.5, 2}]}}], Axes -> True, 
          AxesLabel -> {"x", "t"}, PlotRange -> {{-2, 3}, {-0.5, 5}}, 
          AspectRatio -> 1, PlotLabel -> "Twin Paradox", ImageSize -> 400]], 
      "Specifications" :> {{{$CellContext`vTwin$$, 0.6, 
          "Travel velocity v/c"}, 0.1, 0.95, 0.01}}, "Options" :> {}, 
      "DefaultOptions" :> {}],
     ImageSizeCache->{449.1, {250.8774837917752, 256.60941738552515`}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    SynchronousInitialization->True,
    UndoTrackedVariables:>{Typeset`show$$, Typeset`bookmarkMode$$},
    UnsavedVariables:>{Typeset`initDone$$},
    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
   Deployed->True,
   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
 CellChangeTimes->{3.983003350939534*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"bcb9c331-4a7c-4fe5-b462-631cd26711bd"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. Index Manipulation with the Metric", "Section",ExpressionUUID->"00aad1b1-0bb7-42fb-af5f-b67b3af171af"],

Cell["\<\
Demonstrate raising and lowering indices using the Minkowski metric. V_mu = \
eta_{mu nu} V^nu flips the sign of the time component. (Carroll eqs. \
1.72--1.75)\
\>", "Text",ExpressionUUID->"0689d4c0-24b6-43ca-bc99-c4adb884759e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Example", ":", " ", 
    RowBox[{
     RowBox[{
     "lower", " ", "the", " ", "index", " ", "of", " ", "a", " ", "four"}], "-",
      "vector"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", " ", "1", ",", " ", "1", ",", " ", "1"}], 
       "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Vup", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"E0", ",", " ", "px", ",", " ", "py", ",", " ", "pz"}], "}"}]}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"Vdown", " ", "=", " ", 
     RowBox[{"\[Eta]", " ", ".", " ", "Vup"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<V^\[Mu] = \>\"", ",", " ", "Vup"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<V_\[Mu] = \[Eta]_{\[Mu]\[Nu]} V^\[Nu] = \>\"", ",", " ", 
      "Vdown"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Note: V_0 = -V^0 (sign flip), V_i = V^i (no \
change)\>\"", "]"}], ";"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Compute", " ", "the", " ", "invariant", " ", "norm", " ", 
     RowBox[{"V", "^", "mu"}], " ", "V_mu"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"norm", " ", "=", " ", 
     RowBox[{"Vup", " ", ".", " ", "Vdown"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<V^\[Mu] V_\[Mu] = \>\"", ",", " ", "norm"}], "]"}], 
    ";"}]}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"374338b4-2d41-4222-9487-4aab9e229dc0"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"V^\[Mu] = \"\>", "\[InvisibleSpace]", 
   RowBox[{"{", 
    RowBox[{"E0", ",", "px", ",", "py", ",", "pz"}], "}"}]}],
  SequenceForm[
  "V^\[Mu] = ", {$CellContext`E0, $CellContext`px, $CellContext`py, \
$CellContext`pz}],
  Editable->False]], "Print",
 CellChangeTimes->{3.983003350960072*^9},
 CellLabel->
  "During evaluation of \
In[9]:=",ExpressionUUID->"b4e3ae0e-e0ff-40c2-8cbb-63698ca87fb9"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"V_\[Mu] = \[Eta]_{\[Mu]\[Nu]} V^\[Nu] = \"\>", "\[InvisibleSpace]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "E0"}], ",", "px", ",", "py", ",", "pz"}], "}"}]}],
  SequenceForm[
  "V_\[Mu] = \[Eta]_{\[Mu]\[Nu]} V^\[Nu] = ", {-$CellContext`E0, \
$CellContext`px, $CellContext`py, $CellContext`pz}],
  Editable->False]], "Print",
 CellChangeTimes->{3.983003350960565*^9},
 CellLabel->
  "During evaluation of \
In[9]:=",ExpressionUUID->"09900604-0da6-4c8a-b3a9-a3428d8822f0"],

Cell[BoxData["\<\"Note: V_0 = -V^0 (sign flip), V_i = V^i (no change)\"\>"], \
"Print",
 CellChangeTimes->{3.9830033509611187`*^9},
 CellLabel->
  "During evaluation of \
In[9]:=",ExpressionUUID->"67c26e1f-480c-42c5-b50a-46566741a2bc"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"V^\[Mu] V_\[Mu] = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["E0", "2"]}], "+", 
    SuperscriptBox["px", "2"], "+", 
    SuperscriptBox["py", "2"], "+", 
    SuperscriptBox["pz", "2"]}]}],
  SequenceForm[
  "V^\[Mu] V_\[Mu] = ", -$CellContext`E0^2 + $CellContext`px^2 + \
$CellContext`py^2 + $CellContext`pz^2],
  Editable->False]], "Print",
 CellChangeTimes->{3.983003350961411*^9},
 CellLabel->

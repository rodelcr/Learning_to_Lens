Cell["Classify given event separations (cf. LaTeX Exercise 1.1):", "Text",ExpressionUUID->"b0b00b60-cafc-424a-a78b-a017dcf57de3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Exercise", ":", " ", 
    RowBox[{"Classify", " ", "event", " ", "separations"}]}], " ", "*)"}], 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Event", " ", "pairs", " ", "from", " ", "the", " ", "problem", " ", 
    "set"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"events", " ", "=", " ", 
     RowBox[{"{", "\n", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"2", ",", "1", ",", "1", ",", "0"}], "}"}], "}"}], ",", "\n", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", "1", ",", "0", ",", "0"}], "}"}], "}"}], ",", "\n", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"3", ",", "1", ",", "2", ",", "2"}], "}"}], "}"}]}], "}"}]}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"classifyInterval", "[", 
     RowBox[{"eventA_", ",", " ", "eventB_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"dx", ",", " ", "ds2"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"dx", " ", "=", " ", 
        RowBox[{"eventB", " ", "-", " ", "eventA"}]}], ";", "\n", 
       RowBox[{"ds2", " ", "=", " ", 
        RowBox[{"dx", " ", ".", " ", "\[Eta]", " ", ".", " ", "dx"}]}], ";", 
       "\n", 
       RowBox[{"Which", "[", 
        RowBox[{
         RowBox[{"ds2", " ", "<", " ", "0"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"ds2", ",", " ", "\"\<Timelike\>\""}], "}"}], ",", "\n", 
         RowBox[{"ds2", " ", "==", " ", "0"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"ds2", ",", " ", "\"\<Null\>\""}], "}"}], ",", "\n", 
         RowBox[{"ds2", " ", ">", " ", "0"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"ds2", ",", " ", "\"\<Spacelike\>\""}], "}"}]}], "]"}]}]}], 
     "]"}]}], "\n", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"events", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "2"}], "]"}], "]"}], ",", " ", 
        RowBox[{"classifyInterval", "[", 
         RowBox[{
          RowBox[{"events", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", " ", 
          RowBox[{"events", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "]"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"i", ",", " ", "3"}], "}"}]}], "]"}], " ", "//", " ", 
    "TableForm"}]}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"5d0450bf-b184-422d-82d7-8154aa888c63"],


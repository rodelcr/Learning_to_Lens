Cell[CellGroupData[{

Cell["4. Time Dilation Demonstration", "Section",ExpressionUUID->"ce8428ba-c3c2-46e0-886e-2efae1fb307a"],

Cell["\<\
The Lorentz factor gamma = 1/Sqrt[1 - v^2] determines how much a moving clock \
slows down relative to a stationary observer. This plot shows gamma as a \
function of v/c.\
\>", "Text",ExpressionUUID->"013b198c-281e-4460-8fcf-9819eb982af5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Plot", " ", "the", " ", "Lorentz", " ", "factor", " ", "gamma", " ", "vs",
     " ", "velocity"}], " ", "*)"}], "\n", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{"v", "^", "2"}]}], "]"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"v", ",", " ", "0", ",", " ", "0.999"}], "}"}], ",", "\n", 
    RowBox[{"PlotRange", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "25"}], "}"}]}], ",", "\n", 
    RowBox[{"AxesLabel", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<v/c\>\"", ",", " ", "\"\<\[Gamma]\>\""}], "}"}]}], ",", 
    "\n", 
    RowBox[{
    "PlotLabel", " ", "->", 
     " ", "\"\<Lorentz Factor \[Gamma] = 1/\\!\\(\\*SqrtBox[\\(1 - \
v\\^2/c\\^2\\)]\\)\>\""}], ",", "\n", 
    RowBox[{"PlotStyle", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"Blue", ",", " ", "Thick"}], "}"}]}], ",", "\n", 
    RowBox[{"GridLines", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0.5", ",", " ", "0.9", ",", " ", "0.99"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "2", ",", " ", "5", ",", " ", "10"}], "}"}]}], 
      "}"}]}], ",", "\n", 
    RowBox[{"Epilog", " ", "->", " ", 
     RowBox[{"{", "\n", 
      RowBox[{
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"\"\<v = 0.5c: \[Gamma] = 1.15\>\"", ",", " ", "10"}], 
          "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"0.5", ",", " ", "3"}], "}"}]}], "]"}], ",", "\n", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"\"\<v = 0.9c: \[Gamma] = 2.29\>\"", ",", " ", "10"}], 
          "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"0.75", ",", " ", "5"}], "}"}]}], "]"}], ",", "\n", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"\"\<v = 0.99c: \[Gamma] = 7.09\>\"", ",", " ", "10"}], 
          "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"0.85", ",", " ", "10"}], "}"}]}], "]"}]}], "}"}]}], ",", 
    "\n", 
    RowBox[{"ImageSize", " ", "->", " ", "500"}]}], "]"}]}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"74c14af0-2621-4cc0-b07b-59e83ebccc95"],

